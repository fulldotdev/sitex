{
  "name": "sitex",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./island": "./sitex/hydration/server.tsx",
    "./plugin": "./sitex/vite/plugin.ts",
    "./tsconfig": "./sitex/config/tsconfig.json",
    "./virtual": "./sitex/types/virtual.d.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4323",
    "start": "pnpm dev",
    "format": "prettier --write .",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm typecheck",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4323",
    "changeset": "changeset",
    "release": "changeset version && pnpm install --lockfile-only",
    "release:publish": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.13",
    "@vitejs/plugin-react": "^5.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.8.3",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.2"
  }
}
