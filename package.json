{
  "name": "sitex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run @fulldotdev/sitex#check && vp run -r build",
    "dev": "vp run docs#dev",
    "build": "vp run -r build",
    "check": "vp check && vp run @fulldotdev/sitex#check",
    "format": "vp fmt",
    "preview": "vp run docs#preview",
    "changeset": "changeset",
    "release": "changeset version && pnpm install --lockfile-only",
    "release:publish": "vp run -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "vite-plus": "^0.2.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.1.2"
}
