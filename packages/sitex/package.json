{
  "name": "@fulldotdev/sitex",
  "version": "0.4.0",
  "description": "A simpler React framework for building content sites.",
  "homepage": "https://github.com/fulldotdev/sitex#readme",
  "bugs": {
    "url": "https://github.com/fulldotdev/sitex/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fulldotdev/sitex.git"
  },
  "files": [
    "dist",
    "src/config",
    "src/types"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./island": {
      "types": "./dist/hydration/server.d.ts",
      "default": "./dist/hydration/server.js"
    },
    "./plugin": {
      "types": "./dist/vite/plugin.d.ts",
      "default": "./dist/vite/plugin.js"
    },
    "./tsconfig": "./src/config/tsconfig.json",
    "./virtual": "./src/types/virtual.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "fast-glob": "catalog:",
    "parse5": "catalog:",
    "satteri": "catalog:",
    "schema-dts": "catalog:",
    "yaml": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "vite": ">=8",
    "vite-plus": ">=0.1.24"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.1.3",
    "vite-plus": "^0.2.3"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
